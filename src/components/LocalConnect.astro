---
// Location & Social Metadata
const location = "612 East Main St. Meriden, CT , 06450";
const hours = [
  { day: "Mon", time: "CLOSED" },
  { day: "TUE - SUN", time: "12:00 AM - 7:00 PM" },
];

const socials = [
  { name: "TikTok", url: "#", iconPath: "M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.86-.6-4.12-1.31a6.38 6.38 0 0 1-1.87-1.54l-.01 5.4c.03 2.22-.65 4.54-2.18 6.13-1.66 1.76-4.14 2.53-6.47 2.23-2.6-.22-5.07-1.92-5.99-4.4a8.6 8.6 0 0 1-.39-4.7c.48-2.6 2.45-4.94 4.96-5.74.88-.28 1.8-.4 2.72-.37V10c-1.35-.06-2.75.29-3.86 1.07a5.53 5.53 0 0 0-2.3 3.86c-.23 1.5.07 3.1.92 4.35.88 1.34 2.44 2.2 4.02 2.28 1.45.09 2.97-.4 3.92-1.51.98-1.07 1.25-2.6 1.22-4.01l.01-16.08Z" },
  { name: "Instagram", url: "#", iconPath: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.778 6.98 6.978 1.28.058 1.688.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" },
  { name: "Facebook", url: "#", iconPath: "M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z" }
];
---

<section 
  aria-labelledby="connect-heading" 
  class="relative z-50 px-4 mb-24 mt-20 animate-in"
>
  <div class="container mx-auto max-w-5xl">
    <div class="bg-white/10 backdrop-blur-xl border border-white/30 shadow-2xl rounded-3xl p-8 md:p-16 flex flex-col md:flex-row items-center justify-between gap-12 text-center md:text-left">
      
      <address class="animate-item flex-1 not-italic space-y-6">
        <h2 id="connect-heading" class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white drop-shadow-md">
          Visit the <span class="text-hot-pink">Tropics</span>
        </h2>
        
        <div class="space-y-1">
          <p class="text-white font-bold text-lg">{location}</p>
          <div class="flex flex-col gap-1">
            {hours.map((h) => (
              <div class="flex justify-center md:justify-start gap-4 text-white/90 font-medium">
                <span class="w-24 text-emerald font-black uppercase text-xs tracking-widest">{h.day}</span>
                <span>{h.time}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="pt-6 space-y-4">
          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-tropical-teal">Like and Follow Us!</h3>
          <div class="flex justify-center md:justify-start gap-6">
            {socials.map((s) => (
              <a 
                href={s.url} 
                aria-label={`Follow us on ${s.name}`}
                class="group relative bg-white/20 p-4 rounded-2xl transition-all hover:bg-hot-pink hover:scale-110 active:scale-95 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-hot-pink"
              >
                <svg class="w-6 h-6 fill-white transition-transform group-hover:rotate-12" viewBox="0 0 24 24">
                  <path d={s.iconPath} />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </address>

      <div class="animate-item flex-shrink-0">
        <a 
          href="https://g.page/review/example" 
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            "inline-flex items-center gap-3 px-10 py-6 text-xl font-black uppercase tracking-widest text-white transition-all",
            "bg-linear-to-r from-yellow-400 to-hot-pink rounded-full select-none",
            "shadow-xl hover:shadow-[0_20px_40px_rgba(255,105,180,0.4)] hover:scale-105 active:scale-95",
            "inset-shadow-sm inset-shadow-white/60 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-offset-2 focus-visible:ring-yellow-400"
          ]}
        >
          <svg class="w-8 h-8 fill-white drop-shadow-md" viewBox="0 0 24 24">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2L9.19 8.63L2 9.24l5.46 4.73L5.82 21z" />
          </svg>
          <span>Rate us on Google!</span>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* Ensuring WCAG contrast for secondary info */
  address p, address span {
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  /* Anti-grid overlap correction for mobile */
  @media (max-width: 768px) {
    section {
      margin-top: -3rem;
    }
  }
</style>