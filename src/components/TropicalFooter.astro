---
// TropicalFooter.astro - The high-contrast, tactile climax of the page.
---

<footer class="relative mt-20 bg-linear-to-t from-hot-pink to-bubblegum pt-24 pb-12 text-white">
  <div class="container mx-auto px-4 flex flex-col items-center">
    
    <div class="mb-16">
      <a 
        href="/menu" 
        class="group relative inline-flex items-center justify-center px-12 py-5 text-xl font-black uppercase tracking-widest text-white transition-all duration-300 ease-out 
               bg-tropical-teal rounded-full shadow-[0_15px_30px_rgba(0,128,128,0.4)] 
               hover:scale-110 hover:shadow-[0_20px_40px_rgba(0,128,128,0.6)] 
               active:scale-95 active:shadow-inner
               focus-visible:ring-4 focus-visible:ring-emerald focus-visible:ring-offset-4 focus-visible:outline-none"
        style="min-width: 250px; min-height: 44px;"
      >
        <span class="relative z-10 drop-shadow-md">View Full Menu</span>
        <div class="absolute top-2 left-6 w-1/4 h-1/5 bg-white/30 blur-[2px] rounded-full pointer-events-none"></div>
      </a>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between w-full border-t border-white/20 pt-12 gap-8">
      
      <div class="text-center md:text-left">
        <h2 class="text-3xl font-black italic tracking-tighter uppercase mb-2">Paradise Frappe</h2>
        <p class="text-white/80 font-medium">Hyper-realistic flavors for the digital soul.</p>
      </div>

      <nav aria-label="Social Media Links" class="flex gap-6">
        <a 
          href="https://tiktok.com/@paradisefrappe" 
          target="_blank" 
          rel="noopener noreferrer"
          aria-label="Follow us on TikTok"
          class="w-12 h-12 flex items-center justify-center bg-white/20 rounded-2xl backdrop-blur-md transition-all duration-300 hover:scale-110 hover:bg-white/40 focus-visible:ring-4 focus-visible:ring-white focus-visible:outline-none"
        >
          <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.06-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.9-.32-1.98-.23-2.81.3a2.91 2.91 0 0 0-1.28 2.02c-.08.64-.04 1.29.13 1.91.24.97.94 1.83 1.83 2.29.83.43 1.8.54 2.71.32 1.22-.29 2.17-1.31 2.45-2.54.06-.34.07-.68.07-1.02.01-4.73 0-9.46 0-14.19Z"/>
          </svg>
        </a>

        <a 
          href="https://facebook.com/paradisefrappe" 
          target="_blank" 
          rel="noopener noreferrer"
          aria-label="Follow us on Facebook"
          class="w-12 h-12 flex items-center justify-center bg-white/20 rounded-2xl backdrop-blur-md transition-all duration-300 hover:scale-110 hover:bg-white/40 focus-visible:ring-4 focus-visible:ring-white focus-visible:outline-none"
        >
          <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </nav>
    </div>

    <div class="mt-12 text-sm text-white/60 font-medium">
      &copy; {new Date().getFullYear()} Paradise Frappe. Built for Alex Martinez in New Haven.
    </div>
  </div>
</footer>