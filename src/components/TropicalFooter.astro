---
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-gray-950 pt-16 pb-8 overflow-hidden w-full border-t border-white/5">
  <div class="absolute top-0 left-0 w-full rotate-180 leading-[0] opacity-20">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none" class="relative block w-full h-[40px] fill-hot-pink">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z"></path>
    </svg>
  </div>

  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="text-center md:text-left">
        <h2 class="text-2xl font-black uppercase italic text-white tracking-tighter">
          Paradise <span class="text-hot-pink">Frappe</span>
        </h2>
        <p class="text-white/40 font-bold mt-1 uppercase tracking-[0.2em] text-[10px]">
          Hyper-realistic flavors for the digital soul.
        </p>
      </div>

      <div class="flex gap-4">
        <a href="https://tiktok.com" target="_blank" aria-label="TikTok" class="p-3 bg-white/5 rounded-xl hover:bg-hot-pink/20 transition-all border border-white/10 hover:border-hot-pink/50 group">
          <svg class="w-5 h-5 fill-white group-hover:fill-hot-pink transition-colors" viewBox="0 0 24 24">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.03-1.03-2.28-1.39-3.41-4.21-2.71-6.73.53-2.14 2.37-3.89 4.5-4.28 1.05-.2 2.14-.11 3.14.28V12.5c-1-.28-2.07-.3-3.1-.06-1.42.33-2.61 1.58-2.81 3.01-.14 1.25.41 2.53 1.41 3.29.93.71 2.15.93 3.3.61 1.1-.28 1.98-1.17 2.22-2.27.1-.48.11-.97.11-1.46V.02z"/>
          </svg>
        </a>

        <a href="https://facebook.com" target="_blank" aria-label="Facebook" class="p-3 bg-white/5 rounded-xl hover:bg-hot-pink/20 transition-all border border-white/10 hover:border-hot-pink/50 group">
          <svg class="w-5 h-5 fill-white group-hover:fill-hot-pink transition-colors" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/5 text-center flex flex-col gap-2">
      <p class="text-white/20 text-[9px] font-bold uppercase tracking-[0.4em]">
        {currentYear} • New Haven, CT
      </p>
      
      <a 
        href="https://www.casatechllc.com" 
        target="_blank" 
        class="text-white/30 text-[8px] font-black uppercase tracking-[0.5em] hover:text-hot-pink transition-colors duration-300"
      >
        Powered by <span class="underline decoration-hot-pink/30 underline-offset-4">Casatech LLC</span>
      </a>
    </div>
  </div>
</footer>