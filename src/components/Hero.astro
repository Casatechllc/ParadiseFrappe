---
import { Image } from 'astro:assets';

// Placeholder imports - Replace these with your actual asset paths
import frappeImg from '../assets/pineapple-strawberry-mango.png';
import flamingoImg from '../assets/flamingo3.png';
import leafImg from '../assets/monster-leaf.png';

// const frappeImg = '../assets/pineapple-strawberry-mango.png';
// const flamingoImg = "https://placehold.co/400x600/hot-pink/white?text=Flamingo";
// const leafImg = "https://placehold.co/300x300/emerald/white?text=Leaf";
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-0">
  
  <div class="absolute inset-0 z-0 pointer-events-none select-none">
    <div class="absolute -left-16 bottom-0 md:left-0 opacity-80 rotate-12">
       <Image src={flamingoImg} alt="" width={450} height={650} class="object-contain" />
    </div>
    <div class="absolute -right-16 bottom-0 md:right-0 opacity-80 -rotate-12 scale-x-[-1]">
       <Image src={flamingoImg} alt="" width={450} height={650} class="object-contain" />
    </div>
    <div class="absolute top-20 left-1/4 -z-10 blur-sm opacity-40">
      <Image src={leafImg} alt="" width={300} height={300} />
    </div>
    <div class="absolute bottom-20 right-1/4 -z-10 blur-sm opacity-40 rotate-90">
      <Image src={leafImg} alt="" width={300} height={300} />
    </div>
  </div>

  <div class="container relative z-10 px-4 flex flex-col items-center">
    
    <div class="relative mb-[-80px] z-0 transition-transform duration-500 hover:scale-105">
      <Image 
        src={frappeImg} 
        alt="A tropical Pineapple drink" 
        width={500} 
        height={700}
        loading="eager"
        fetchpriority="high"
        class="drop-shadow-[0_35px_35px_rgba(255,105,180,0.5)] saturate-150 contrast-110 brightness-110"
      />
    </div>

    <div class="relative z-20 max-w-2xl w-full bg-white/20 backdrop-blur-xl border border-white/30 shadow-2xl rounded-3xl p-8 md:p-12 text-center">
      <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-white leading-none mb-6"
          style="text-shadow: 4px 4px 0px var(--color-hot-pink), 8px 8px 0px var(--color-tropical-teal); -webkit-text-stroke: 2px white;">
        Taste the <span class="text-hot-pink">Paradise</span>
      </h1>
      
      <p class="text-lg md:text-xl font-medium text-gray-800 dark:text-white mb-8 max-w-md mx-auto">
        Escape the heat with our dopamine-infused tropical blends. Hand-crafted, ice-cold, and dangerously refreshing.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="bg-emerald hover:bg-tropical-teal text-white font-bold py-4 px-10 rounded-full transition-all transform hover:scale-105 shadow-xl">
          Order Now
        </button>
        <button class="bg-white/30 hover:bg-white/50 text-white font-bold py-4 px-10 rounded-full transition-all border border-white/20">
          Find a Location
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Custom text-shadow layering to create a "Bubbly" thick stroke effect */
  h1 {
    font-family: 'BubblyVariable', sans-serif;
    filter: drop-shadow(0 10px 10px rgba(0,0,0,0.2));
  }
</style>